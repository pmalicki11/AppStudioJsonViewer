<Window x:Class="AppStudioJsonViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="App Studio JSON Viewer — KNTCCustLayer" Height="600" Width="900"
        Icon="Resources/icon.ico"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">

        <!-- Filters + environment selector -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Application ID" Foreground="{StaticResource Fg.Muted}" VerticalAlignment="Center"
                           Margin="0,0,6,0" DockPanel.Dock="Left" />
                <TextBox x:Name="Key2Filter" Padding="4,3" TextChanged="Filter_TextChanged" />
            </DockPanel>
            <DockPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Layer Name" Foreground="{StaticResource Fg.Muted}" VerticalAlignment="Center"
                           Margin="0,0,6,0" DockPanel.Dock="Left" />
                <TextBox x:Name="Key1Filter" Padding="4,3" TextChanged="Filter_TextChanged" />
            </DockPanel>
            <ComboBox x:Name="EnvironmentComboBox" Grid.Column="2" Width="140" Margin="0,0,8,0"
                      SelectionChanged="EnvironmentComboBox_SelectionChanged" />
            <Button x:Name="LoadButton" Grid.Column="3" Content="Load"
                    Padding="12,4" VerticalAlignment="Stretch" Click="LoadButton_Click" />
        </Grid>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource Fg.Muted}" />
        </Border>

        <!-- Grid of rows (with a loading overlay on top) -->
        <Grid>
            <DataGrid x:Name="RowsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      BorderBrush="{StaticResource Border.Default}" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Application ID" Binding="{Binding Key2}" Width="2*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="6,2" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Layer Name" Width="3*" SortMemberPath="Key1">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="6,2" VerticalAlignment="Center">
                                    <Hyperlink Click="Key1_Click">
                                        <Run Text="{Binding Key1}" />
                                    </Hyperlink>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Loading overlay: dims the grid and shows an animated progress bar -->
            <Border x:Name="LoadingOverlay" Visibility="Collapsed"
                    Background="#CC1E1E1E">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Loading…" FontSize="14" Foreground="#444"
                               HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <ProgressBar IsIndeterminate="True" Width="180" Height="6" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
