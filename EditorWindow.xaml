<Window x:Class="AppStudioJsonViewer.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Content" Height="700" Width="900"
        Icon="Resources/icon.ico"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">

        <!-- Buttons -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0" LastChildFill="False">
            <TextBlock x:Name="StatusText" DockPanel.Dock="Left"
                       VerticalAlignment="Center" Foreground="{StaticResource Fg.Muted}" />
            <Button x:Name="CloseButton" DockPanel.Dock="Right" Content="Close"
                    Padding="14,5" Margin="8,0,0,0" Click="CloseButton_Click" />
            <Button x:Name="SaveButton" DockPanel.Dock="Right" Content="Save (minify → DB)"
                    Padding="14,5" Margin="8,0,0,0" Click="SaveButton_Click"
                    FontWeight="SemiBold" />
            <Button x:Name="ReformatButton" DockPanel.Dock="Right" Content="Reformat"
                    Padding="14,5" Click="ReformatButton_Click" />
        </DockPanel>

        <!-- JSON editor -->
        <Border BorderBrush="{StaticResource Border.Default}" BorderThickness="1">
            <avalonedit:TextEditor x:Name="Editor"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="13"
                                   ShowLineNumbers="True"
                                   WordWrap="False"
                                   Background="#1E1E1E"
                                   Foreground="#D4D4D4"
                                   LineNumbersForeground="#858585"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto" />
        </Border>
    </DockPanel>
</Window>
