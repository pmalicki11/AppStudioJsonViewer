<Application x:Class="AppStudioJsonViewer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AppStudioJsonViewer"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Implicit styles are matched by the element's exact type, so the
                 generic Window style in DarkTheme.xaml never reaches our Window
                 subclasses. Re-point it at the concrete windows so their client
                 area (background + foreground) is themed too. -->
            <Style TargetType="{x:Type local:MainWindow}"
                   BasedOn="{StaticResource {x:Type Window}}" />
            <Style TargetType="{x:Type local:EditorWindow}"
                   BasedOn="{StaticResource {x:Type Window}}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
